# .env 文件
# Docker Compose 环境变量

USER_NAME=ukyang
USER_NAME_CN=马阳
USER_EMAIL=ukyang@0623@gmail.com
# 1. 网络代理配置（WSL 宿主机的代理）
# 获取 WSL 宿主机 IP: cat /etc/resolv.conf | grep nameserver | awk '{print $2}'
HTTP_PROXY=http://172.29.128.1:7897
HTTPS_PROXY=http://172.29.128.1:7897

# 2. 路径配置
# DOTFILE_DIR=/root/dotfile

# CONFIG_DIR=./config

# 3. 容器标签
PROJECT_NAME=dev-environment
COMPOSE_PROJECT_NAME=dev-env

# 4. 调试选项
COMPOSE_HTTP_TIMEOUT=300
DOCKER_BUILDKIT=1
